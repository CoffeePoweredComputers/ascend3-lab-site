---
/**
 * PersonCard — Compact lab member profile card
 *
 * Static bio line, name links to website when available.
 * Collaborators use secondary accent.
 */

interface Props {
  name: string;
  role: string;
  photo?: string;
  bio?: string;
  website?: string;
  institution?: string;
  isCollaborator?: boolean;
}

const { name, role, photo, bio, website, institution, isCollaborator = false } = Astro.props;
const initials = name.split(' ').map(n => n[0]).join('').slice(0, 2);
---

<div class:list={[
  'card p-3 flex flex-col items-center text-center',
  isCollaborator ? 'hover:border-secondary hover:shadow-[0_4px_24px_rgba(22,101,52,0.08)]' : ''
]}>
  <!-- Photo -->
  {photo ? (
    <img
      src={photo}
      alt={`Photo of ${name}`}
      class:list={[
        'w-14 h-14 rounded-full object-cover mb-3 ring-1 ring-offset-1 ring-offset-surface-base',
        isCollaborator ? 'ring-secondary/50' : 'ring-primary/50'
      ]}
      loading="lazy"
    />
  ) : (
    <div class:list={[
      'w-14 h-14 rounded-full mb-3 flex items-center justify-center font-heading font-bold text-base ring-1 ring-offset-1 ring-offset-surface-base',
      isCollaborator
        ? 'bg-secondary/10 text-secondary ring-secondary/50'
        : 'bg-primary/10 text-primary ring-primary/50'
    ]}>
      {initials}
    </div>
  )}

  <!-- Name (links to website when available) -->
  <h3 class="font-heading font-semibold text-text text-base">
    {website ? (
      <a
        href={website}
        class="no-underline text-text hover:text-primary transition-colors"
        target="_blank"
        rel="noopener noreferrer"
      >
        {name} <span class="text-text-muted text-xs" aria-hidden="true">↗</span>
        <span class="sr-only">(opens in new tab)</span>
      </a>
    ) : name}
  </h3>

  <!-- Role -->
  <p class:list={[
    'font-mono text-xs mt-1',
    isCollaborator ? 'text-secondary' : 'text-primary'
  ]}>
    {role}
  </p>

  <!-- Institution (for collaborators) -->
  {institution && (
    <p class="text-text-muted text-xs mt-0.5">{institution}</p>
  )}

  <!-- Bio -->
  {bio && (
    <p class="text-text-muted text-sm mt-2 leading-relaxed">{bio}</p>
  )}

</div>
