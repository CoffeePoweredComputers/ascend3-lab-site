---
/**
 * NewsSection — Filter chips + compact scrollable list of news items
 */
import SectionHeading from '../SectionHeading.astro';
import newsData from '../../data/news.json';

const types = ['all', 'publication', 'talk', 'grant', 'general'] as const;
---

<section id="news" class="section">
  <div class="container max-w-3xl">
    <SectionHeading
      title="News"
      subtitle="Publications, talks, grants, and lab announcements."
    />

    <!-- Filter chips -->
    <div role="group" aria-label="Filter by type" class="flex flex-wrap gap-2 mb-4">
      {types.map((type) => (
        <button
          class:list={['news-filter-chip', `news-filter-chip--${type}`]}
          aria-pressed={type === 'all' ? 'true' : 'false'}
          data-filter={type}
        >
          {type === 'all' ? 'All' : type}
        </button>
      ))}
    </div>

    <!-- Scrollable news list -->
    <div
      class="news-scroll-container"
      role="region"
      aria-label="News items"
      tabindex="0"
    >
      {newsData.map((item, i) => (
        <div class="news-item" data-type={item.type}>
          <button
            class="news-row"
            aria-expanded="false"
            aria-controls={`news-detail-${i}`}
          >
            <time
              datetime={item.date}
              class="news-row-date"
            >
              {new Date(item.date + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
            <span class:list={['badge', `badge-${item.type}`, 'news-row-badge']}>
              {item.type}
            </span>
            <span class="news-row-title">{item.title}</span>
            <span class="news-row-chevron" aria-hidden="true">&#x25B8;</span>
          </button>
          <div id={`news-detail-${i}`} class="news-detail">
            <p class="text-text-muted text-sm leading-relaxed">{item.description}</p>
            {item.links && item.links.length > 0 && (
              <div class="flex flex-wrap gap-3 mt-2">
                {item.links.map((link: { text: string; url: string }) => (
                  <a
                    href={link.url}
                    class="font-mono text-xs text-primary hover:text-secondary no-underline transition-colors"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {link.text} <span aria-hidden="true">&uarr;</span>
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initNews() {
    const filterButtons = document.querySelectorAll<HTMLButtonElement>('.news-filter-chip');
    const newsItems = document.querySelectorAll<HTMLElement>('.news-item');
    const rowButtons = document.querySelectorAll<HTMLButtonElement>('.news-row');

    // Filter logic
    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter!;

        // Update pressed state
        filterButtons.forEach((b) => b.setAttribute('aria-pressed', 'false'));
        btn.setAttribute('aria-pressed', 'true');

        // Collapse all expanded rows
        rowButtons.forEach((rb) => {
          rb.setAttribute('aria-expanded', 'false');
          const detailId = rb.getAttribute('aria-controls');
          if (detailId) {
            const detail = document.getElementById(detailId);
            if (detail) detail.hidden = true;
          }
        });

        // Show/hide items
        newsItems.forEach((item) => {
          if (filter === 'all' || item.dataset.type === filter) {
            item.hidden = false;
          } else {
            item.hidden = true;
          }
        });
      });
    });

    // Expand/collapse logic
    rowButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        const detailId = btn.getAttribute('aria-controls');
        if (!detailId) return;
        const detail = document.getElementById(detailId);
        if (!detail) return;

        btn.setAttribute('aria-expanded', String(!expanded));
        detail.hidden = expanded;
      });
    });

    // Initialize all detail panels as hidden
    document.querySelectorAll<HTMLElement>('.news-detail').forEach((d) => {
      d.hidden = true;
    });
  }

  // Run on initial load and on Astro page transitions
  initNews();
  document.addEventListener('astro:after-swap', initNews);
</script>
