---
/**
 * ResearchSection — Research areas grid
 */
import SectionHeading from '../SectionHeading.astro';
import PeopleStack from '../PeopleStack.astro';
import researchData from '../../data/research.json';

const iconMap: Record<string, string> = {
  brain: '🧠',
  check: '✓',
  code: '</>',
  globe: '🌐',
  scale: '⚖',
  database: '🗃',
};
---

<section id="research" class="section">
  <div class="container">
    <SectionHeading
      title="Research"
      subtitle="Our research spans the intersection of artificial intelligence, computing education, and human-computer interaction."
    />

    <div class="grid md:grid-cols-2 gap-8">
      {researchData.map((item) => (
        <div class="card p-6 md:p-8">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-3xl font-mono text-primary" aria-hidden="true">
              {iconMap[item.icon] || '▸'}
            </span>
            <h3 class="font-heading font-semibold text-xl text-text">{item.title}</h3>
          </div>
          <p class="text-text-muted leading-relaxed">{item.description}</p>
          <div class="flex flex-wrap gap-2 mt-5">
            {item.keywords.map((kw: string) => (
              <span class="text-xs font-mono px-2.5 py-1 rounded-full bg-primary/10 text-primary/80 border border-primary/20">
                {kw}
              </span>
            ))}
          </div>
          {item.researchers && item.researchers.length > 0 && (
            <div class="mt-5 pt-4 border-t border-border/50">
              <PeopleStack memberIds={item.researchers} label="Researchers" />
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Call to Action -->
    <div class="mt-16 text-center">
      <p class="text-text-muted mb-4">Interested in our research?</p>
      <a
        href="#join"
        class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white rounded-lg font-medium text-sm hover:bg-primary/90 no-underline transition-colors"
      >
        Join the lab
      </a>
    </div>
  </div>
</section>
