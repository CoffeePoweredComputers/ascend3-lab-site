---

<!-- ═══ DESKTOP SIDEBAR ═══ -->
<aside
  class="hidden lg:flex fixed left-0 top-0 bottom-0 w-[340px] z-40 flex-col"
  aria-label="Sidebar navigation"
>
  <!-- Frosted glass background -->
  <div class="absolute inset-0 bg-white/60 dark:bg-surface-base/60 backdrop-blur-xl border-r border-border/50"></div>

  <!-- Animated topo lines background -->
  <div class="absolute inset-0 topo-sidebar opacity-30 pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 flex flex-col h-full px-6 py-6">

    <!-- ═══ Section 1: Logo (fixed size) ═══ -->
    <div class="shrink-0 mb-6">
      <a
        href="#home"
        id="nav-logo"
        class="block no-underline group"
        aria-label="ASCEND Lab - Home"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          xml:space="preserve"
          viewBox="0 0 327.416 85.588"
          class="w-full h-auto transition-transform duration-300 group-hover:scale-[1.02] dark:hidden"
          set:html={logoSvgContent}
        />
        <img
          src="/assets/ascend-logo-dark.svg"
          alt=""
          class="w-full h-auto transition-transform duration-300 group-hover:scale-[1.02] hidden dark:block"
        />
      </a>
    </div>

    <!-- ═══ Section 2: Trail nav (fills remaining space) ═══ -->
    <nav aria-label="Main navigation" class="flex-1 min-h-0">
      <div class="relative h-full mx-auto" style={`width: ${TRAIL_WIDTH}px;`} data-trail-container>
        <!-- SVG winding trail path (viewBox set by JS) -->
        <svg
          data-trail-svg
          class="absolute inset-0 w-full h-full"
          fill="none"
          aria-hidden="true"
        >
          <defs>
            <linearGradient id="trail-gradient" x1="0" y1="1" x2="0" y2="0">
              <stop offset="0%" stop-color="#166534" />
              <stop offset="50%" stop-color="#2563EB" />
              <stop offset="100%" stop-color="#93C5FD" />
            </linearGradient>
          </defs>
          <path
            data-trail-dashed
            stroke="var(--color-border)"
            stroke-width="2"
            stroke-dasharray="6 4"
            stroke-linecap="round"
            fill="none"
          />
          <path
            data-trail-path
            stroke="url(#trail-gradient)"
            stroke-width="2.5"
            stroke-linecap="round"
            fill="none"
          />
        </svg>

        <!-- Waypoints (positioned via top %) -->
        {waypoints.map((wp) => (
          <a
            href={wp.href}
            data-waypoint={wp.id}
            class:list={[
              'trail-waypoint group absolute no-underline z-10',
              wp.side === 'left' ? 'trail-badge-left' : 'trail-badge-right',
            ]}
            style={`top: ${wp.pct}%; --wp-x: ${wp.x}px;`}
          >
            <span class="trail-badge" style={`--char-count:${wp.label.length}`}>
              <span class="trail-prompt" aria-hidden="true">&gt;&nbsp;</span>
              {wp.label.split('').map((char, i) => (
                <span class="trail-char" style={`--char-i:${i}`}>{char}</span>
              ))}
              <span class="trail-cursor" aria-hidden="true">_</span>
            </span>
          </a>
        ))}
      </div>
    </nav>

    <!-- ═══ Section 3: Footer (fixed size) ═══ -->
    <div class="shrink-0 pt-4 border-t border-border/50 flex items-center justify-between">
      <p class="text-[11px] text-text-muted/60 leading-relaxed">
        Virginia Tech<br/>Dept. of Computer Science
      </p>
      <button
        type="button"
        id="theme-toggle"
        class="theme-toggle p-2 rounded-md text-text-muted hover:text-text hover:bg-surface"
        aria-label="Toggle dark mode"
      >
        <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="1.75em" height="1.75em" fill="currentColor" stroke-linecap="round" class="theme-toggle__classic" viewBox="0 0 32 32">
          <clipPath id="theme-toggle__cutout-d"><path d="M0-5h30a1 1 0 0 0 9 13v24H0Z" /></clipPath>
          <g clip-path="url(#theme-toggle__cutout-d)">
            <circle cx="16" cy="16" r="9.34" />
            <g stroke="currentColor" stroke-width="1.5">
              <path d="M16 5.5v-4" /><path d="M16 30.5v-4" />
              <path d="M1.5 16h4" /><path d="M26.5 16h4" />
              <path d="m23.4 8.6 2.8-2.8" /><path d="m5.7 26.3 2.9-2.9" />
              <path d="m5.8 5.8 2.8 2.8" /><path d="m23.4 23.4 2.9 2.9" />
            </g>
          </g>
        </svg>
      </button>
    </div>

  </div>
</aside>

<!-- ═══ MOBILE TOP BAR ═══ -->
<header class="lg:hidden fixed top-0 left-0 right-0 z-50 bg-white/70 dark:bg-surface-base/70 backdrop-blur-xl border-b border-border/50">
  <div class="flex items-center justify-between px-4 py-3">
    <a href="#home" class="no-underline" aria-label="ASCEND Lab - Home">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        xml:space="preserve"
        viewBox="0 0 327.416 85.588"
        class="h-9 w-auto dark:hidden"
        set:html={logoSvgContent}
      />
      <img
        src="/assets/ascend-logo-dark.svg"
        alt=""
        class="h-9 w-auto hidden dark:block"
      />
    </a>
    <div class="flex items-center gap-1">
      <button
        type="button"
        id="theme-toggle-mobile"
        class="theme-toggle p-2 rounded-md text-text-muted hover:text-text hover:bg-surface"
        aria-label="Toggle dark mode"
      >
        <svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" width="1.75em" height="1.75em" fill="currentColor" stroke-linecap="round" class="theme-toggle__classic" viewBox="0 0 32 32">
          <clipPath id="theme-toggle__cutout-m"><path d="M0-5h30a1 1 0 0 0 9 13v24H0Z" /></clipPath>
          <g clip-path="url(#theme-toggle__cutout-m)">
            <circle cx="16" cy="16" r="9.34" />
            <g stroke="currentColor" stroke-width="1.5">
              <path d="M16 5.5v-4" /><path d="M16 30.5v-4" />
              <path d="M1.5 16h4" /><path d="M26.5 16h4" />
              <path d="m23.4 8.6 2.8-2.8" /><path d="m5.7 26.3 2.9-2.9" />
              <path d="m5.8 5.8 2.8 2.8" /><path d="m23.4 23.4 2.9 2.9" />
            </g>
          </g>
        </svg>
      </button>
      <button
        type="button"
        class="p-2 rounded-md text-text-muted hover:text-text hover:bg-surface transition-colors"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open navigation menu"
        id="mobile-menu-button"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" class="menu-icon"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" class="close-icon hidden"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown -->
  <div id="mobile-menu" class="hidden pb-4 px-4" aria-label="Mobile navigation">
    <ul class="flex flex-col gap-1" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            data-mobile-link={link.id}
            class="flex items-center gap-3 py-3 px-4 rounded-lg font-body font-medium text-sm no-underline transition-colors text-text-muted hover:text-text hover:bg-surface"
          >
            <span class="w-2 h-2 rounded-full flex-shrink-0 border border-text-muted/30" aria-hidden="true"></span>
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>


<script>
  // ── Constants ──
  const SECTION_IDS = ['home', 'about', 'people', 'research', 'projects', 'news', 'join'];
  const NUM_SECTIONS = SECTION_IDS.length;
  const TRAIL_WIDTH = 176;
  const WP_PCTS = SECTION_IDS.map((_id, i) => (5 + (i / (NUM_SECTIONS - 1)) * 90) / 100);

  // ── Randomize trail geometry per page load ──
  function randBetween(min: number, max: number) {
    return Math.floor(Math.random() * (max - min + 1)) + min;
  }

  // Alternate sides: even indices → left half (8–75), odd → right half (100–168)
  const WAYPOINT_XS = SECTION_IDS.map((_id, i) =>
    i % 2 === 0 ? randBetween(8, 75) : randBetween(100, 168)
  );

  // ── DOM refs ──
  const trailContainer = document.querySelector('[data-trail-container]') as HTMLElement | null;
  const trailSvg = document.querySelector('[data-trail-svg]') as SVGSVGElement | null;
  const dashedPath = document.querySelector('[data-trail-dashed]') as SVGPathElement | null;
  const solidPath = document.querySelector('[data-trail-path]') as SVGPathElement | null;
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = menuButton?.querySelector('.menu-icon');
  const closeIcon = menuButton?.querySelector('.close-icon');
  const waypointEls = SECTION_IDS.map(id => document.querySelector(`[data-waypoint="${id}"]`));
  const mobileLinkEls = SECTION_IDS.map(id => document.querySelector(`[data-mobile-link="${id}"]`));

  // ── State ──
  let sectionTops: number[] = [];
  let activeIndex = -1;
  let pathLength = 0;
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Apply randomized X positions to waypoint elements ──
  let xApplied = false;
  function applyWaypointPositions() {
    if (xApplied) return;
    for (let i = 0; i < NUM_SECTIONS; i++) {
      const el = waypointEls[i] as HTMLElement | null;
      if (el) el.style.setProperty('--wp-x', `${WAYPOINT_XS[i]}px`);
    }
    xApplied = true;
  }

  // ── Trail path jitter: drift points + asymmetric control points ──
  // Random values are pre-generated once so the path shape is stable across resizes.
  const DRIFT_COUNT = 2;           // intermediate points per segment
  const DRIFT_X_RANGE = 35;        // max px drift from interpolated X
  const CP_Y_JITTER_FRAC = 0.12;   // ±12% of sub-segment height
  const X_MIN = 8;
  const X_MAX = 168;

  function clamp(v: number, lo: number, hi: number) { return Math.max(lo, Math.min(hi, v)); }

  // Pre-roll all random offsets once at page load
  const DRIFT_X_ROLLS: number[][] = [];
  for (let seg = 0; seg < NUM_SECTIONS - 1; seg++) {
    const offsets: number[] = [];
    for (let k = 0; k < DRIFT_COUNT; k++) {
      offsets.push((Math.random() - 0.5) * 2 * DRIFT_X_RANGE);
    }
    DRIFT_X_ROLLS.push(offsets);
  }

  const TOTAL_SUB_SEGS = (NUM_SECTIONS - 1) * (DRIFT_COUNT + 1);
  const CP_JITTER_ROLLS: number[] = [];
  for (let i = 0; i < TOTAL_SUB_SEGS; i++) {
    CP_JITTER_ROLLS.push((Math.random() - 0.5) * 2 * CP_Y_JITTER_FRAC);
  }

  /** Generate intermediate drift points between two waypoints (deterministic per segment) */
  function driftPoints(a: { x: number; y: number }, b: { x: number; y: number }, segIndex: number) {
    const pts: { x: number; y: number }[] = [];
    for (let k = 0; k < DRIFT_COUNT; k++) {
      const t = (k + 1) / (DRIFT_COUNT + 1);
      const baseX = a.x + (b.x - a.x) * t;
      pts.push({
        x: clamp(baseX + DRIFT_X_ROLLS[segIndex][k], X_MIN, X_MAX),
        y: a.y + (b.y - a.y) * t,
      });
    }
    return pts;
  }

  // ── Draw trail SVG through actual rendered waypoint positions ──
  function drawTrail() {
    if (!trailContainer || !trailSvg || !dashedPath || !solidPath) return;
    applyWaypointPositions();
    const h = trailContainer.clientHeight;
    if (h < 10) return;

    // Read each waypoint's actual center Y from the DOM
    const containerRect = trailContainer.getBoundingClientRect();
    const points: { x: number; y: number }[] = [];

    for (let i = 0; i < NUM_SECTIONS; i++) {
      const el = waypointEls[i];
      const x = WAYPOINT_XS[i];
      if (el) {
        const rect = el.getBoundingClientRect();
        // Anchor at bottom edge where the arrow tip points to the trail
        const anchorY = rect.bottom - containerRect.top;
        points.push({ x, y: anchorY });
      } else {
        // Fallback to computed percentage
        points.push({ x, y: WP_PCTS[i] * h });
      }
    }

    // Expand waypoints → full point sequence with drift points between each pair
    const allPoints: { x: number; y: number }[] = [points[0]];
    for (let i = 1; i < points.length; i++) {
      allPoints.push(...driftPoints(points[i - 1], points[i], i - 1), points[i]);
    }

    // Build cubic bezier path with asymmetric control points — CP X values
    // still match their endpoints so tangents remain vertical (no kinks)
    let d = `M ${allPoints[0].x},${allPoints[0].y}`;
    for (let i = 1; i < allPoints.length; i++) {
      const prev = allPoints[i - 1];
      const curr = allPoints[i];
      const segH = curr.y - prev.y;
      const midY = (prev.y + curr.y) / 2;
      const jitterY = CP_JITTER_ROLLS[i - 1] * segH;
      d += ` C ${prev.x},${midY + jitterY} ${curr.x},${midY - jitterY} ${curr.x},${curr.y}`;
    }

    // Update SVG viewBox and paths
    trailSvg.setAttribute('viewBox', `0 0 ${TRAIL_WIDTH} ${h}`);
    trailSvg.setAttribute('preserveAspectRatio', 'none');

    // Update gradient to use actual pixel coords
    const gradient = trailSvg.querySelector('#trail-gradient');
    if (gradient) {
      gradient.setAttribute('gradientUnits', 'userSpaceOnUse');
      gradient.setAttribute('y1', String(h));
      gradient.setAttribute('y2', '0');
    }

    dashedPath.setAttribute('d', d);
    solidPath.setAttribute('d', d);

    // Preserve current fill ratio across path redraws
    const oldLength = pathLength;
    const oldOffset = parseFloat(solidPath.style.strokeDashoffset) || oldLength;
    const fillRatio = oldLength > 0 ? 1 - oldOffset / oldLength : 0;

    pathLength = solidPath.getTotalLength();
    solidPath.style.strokeDasharray = String(pathLength);

    // Apply preserved ratio without transition to avoid visual jump
    solidPath.style.transition = 'none';
    solidPath.style.strokeDashoffset = String(pathLength * (1 - fillRatio));

    // Re-enable transition for future scroll-driven updates
    if (!prefersReducedMotion) {
      requestAnimationFrame(() => {
        solidPath.style.transition = 'stroke-dashoffset 0.3s ease-out';
      });
    }
  }

  // ── Cache section positions ──
  function cacheSectionPositions() {
    sectionTops = SECTION_IDS.map(id => {
      const el = document.getElementById(id);
      if (!el) return 0;
      return el.getBoundingClientRect().top + window.scrollY;
    });
  }

  // ── Active waypoint styling ──
  function setActiveWaypoint(index: number) {
    if (index === activeIndex) return;

    // Deactivate previous
    if (activeIndex >= 0) {
      const prevWp = waypointEls[activeIndex];
      const prevMobile = mobileLinkEls[activeIndex];
      if (prevWp) {
        prevWp.classList.remove('z-20');
        prevWp.classList.add('z-10');
        prevWp.removeAttribute('aria-current');
      }
      if (prevMobile) {
        prevMobile.classList.remove('text-primary', 'bg-primary/10', 'border-l-2', 'border-primary');
        prevMobile.classList.add('text-text-muted');
        prevMobile.removeAttribute('aria-current');
        const dot = prevMobile.querySelector('span');
        if (dot) {
          dot.classList.remove('bg-primary');
          dot.classList.add('border', 'border-text-muted/30');
        }
      }
    }

    // Activate current
    const wp = waypointEls[index];
    const mobile = mobileLinkEls[index];
    if (wp) {
      wp.classList.remove('z-10');
      wp.classList.add('z-20');
      wp.setAttribute('aria-current', 'true');
    }
    if (mobile) {
      mobile.classList.remove('text-text-muted');
      mobile.classList.add('text-primary', 'bg-primary/10', 'border-l-2', 'border-primary');
      mobile.setAttribute('aria-current', 'true');
      const dot = mobile.querySelector('span');
      if (dot) {
        dot.classList.remove('border', 'border-text-muted/30');
        dot.classList.add('bg-primary');
      }
    }

    activeIndex = index;
  }

  // ── Scroll handler ──
  function onScroll() {
    const scrollY = window.scrollY;
    const triggerY = scrollY + window.innerHeight * 0.4;

    let currentIndex = 0;
    for (let i = NUM_SECTIONS - 1; i >= 0; i--) {
      if (triggerY >= sectionTops[i]) {
        currentIndex = i;
        break;
      }
    }

    setActiveWaypoint(currentIndex);

    // Trail fill progress — use raw scrollY so fill aligns exactly with waypoints
    let progress = 0;
    if (currentIndex < NUM_SECTIONS - 1) {
      const start = sectionTops[currentIndex];
      const end = sectionTops[currentIndex + 1];
      const span = end - start;
      const frac = span > 0 ? Math.min(Math.max((scrollY - start) / span, 0), 1) : 0;
      progress = (currentIndex + frac) / (NUM_SECTIONS - 1);
    } else {
      progress = 1;
    }

    if (solidPath && pathLength > 0) {
      solidPath.style.strokeDashoffset = String(pathLength * (1 - progress));
    }

  }

  // ── Mobile menu ──
  function toggleMobileMenu() {
    const isExpanded = menuButton!.getAttribute('aria-expanded') === 'true';
    menuButton!.setAttribute('aria-expanded', String(!isExpanded));
    menuButton!.setAttribute('aria-label', isExpanded ? 'Open navigation menu' : 'Close navigation menu');
    mobileMenu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  }

  menuButton?.addEventListener('click', toggleMobileMenu);

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      if (!mobileMenu.classList.contains('hidden')) toggleMobileMenu();
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu && !mobileMenu.classList.contains('hidden')) {
      toggleMobileMenu();
    }
  });

  // ── Dark mode ──
  const toggleButtons = document.querySelectorAll<HTMLElement>('.theme-toggle');

  // Set initial toggled state if page loads in dark mode
  if (document.documentElement.classList.contains('dark')) {
    toggleButtons.forEach(btn => btn.classList.add('theme-toggle--toggled'));
  }

  function toggleTheme() {
    const goingDark = !document.documentElement.classList.contains('dark');

    if (!prefersReducedMotion) {
      document.documentElement.classList.add('theme-transitioning');
      void document.documentElement.offsetHeight;
    }

    document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', goingDark ? 'dark' : 'light');
    toggleButtons.forEach(btn => btn.classList.toggle('theme-toggle--toggled'));

    if (!prefersReducedMotion) {
      setTimeout(() => {
        document.documentElement.classList.remove('theme-transitioning');
      }, 650);
    }
  }
  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

  // ── Initialize ──
  function refresh() {
    drawTrail();
    cacheSectionPositions();
    onScroll();
  }

  // Use RAF to ensure layout is settled before first draw
  requestAnimationFrame(refresh);

  // Redraw on resize and if the trail container changes size (font load, etc.)
  window.addEventListener('resize', refresh);
  window.addEventListener('scroll', onScroll, { passive: true });

  if (trailContainer) {
    new ResizeObserver(refresh).observe(trailContainer);
  }
</script>
