;fill-opacity:1;stroke-width:.730913" transform="rotate(-1.887 -3867.566 11175.944)"/><path d="M425.06 207.476c-1.789-.188-1.78-.179-2.118-2.447-.165-1.118-.264-2.041-.218-2.052.045-.01 1.04.244 2.208.566l2.126.587 1.604-1.331c.883-.733 1.733-1.446 1.89-1.587.257-.23.315-.054.592 1.812l.307 2.067-.783.64c-.929.76-4.477 1.864-5.607 1.745m7.516-5.213a21 21 0 0 0-.175-1.962c-.078-.532-.057-.988.046-1.013.108-.026.255.478.346 1.186.088.677.263 1.536.389 1.91.198.59.176.692-.172.776-.364.088-.404.005-.434-.897m-9.443.005c-3.289-.902-3.668-1.06-3.35-1.404.198-.212 1.625-1.444 3.173-2.737l2.813-2.35 3.792 1.035c3.735 1.02 3.784 1.043 3.248 1.486-.3.247-1.72 1.467-3.157 2.71s-2.658 2.264-2.712 2.269c-.055.004-1.768-.45-3.807-1.009" style="fill:#000;stroke-width:.825144" transform="translate(-363.919 -136.217)"/><g style="filter:url(#b)" transform="translate(-39.08 35.122)scale(.09752)"><path d="M635.113 364.632c4.731-2.658 10.178-7.482 12.848-11.378 1.812-2.646 3.555-6.344 4.33-9.19.545-2.004.61-2.812.597-7.408-.013-4.714-.075-5.382-.709-7.726-.86-3.178-2.062-6.207-4.728-11.91-3.61-7.723-4.55-11.188-4.541-16.745.007-4.552 1.045-8.506 2.859-10.883l.653-.857c-15.316 1.119-32.38 7.611-44.716 17.264-3.526 3.018-7.305 8.333-10.817 15.218-1.206 2.364.162 6.396 3.055 9.007 13.138 11.856 26.271 23.719 39.512 35.46.073.003.819-.38 1.657-.852zM629.423 369.62c.436-.478.772-.86 1.022-1.166.451-.554.061-1.6-.506-2.111a49090 49090 0 0 0-21.123-19.016l-21.14-19.022a.93.93 177.237 0 0-1.309.063l-1.282 1.4c-1.333 1.454-3.91 4.34-4.186 4.622-.901.92 44.18 39.825 44.328 39.838.098.008 3.169-3.482 4.196-4.608" style="fill:#000"/><path d="M573.085 402.609c7.027-2.32 13.29-8.198 16.475-15.464.383-.873 1.251-3.433 1.93-5.688 1.9-6.322 3.156-8.22 6.443-9.748 3.72-1.728 8.919-.26 15.986 4.515 3.128 2.113 5.293 2.564 7.462 1.553 1.001-.467 4.07-3.327 3.82-3.56-.064-.061-10.051-9.057-22.194-19.993l-22.077-19.882-1.011 1.134c-1.485 1.665-2.062 2.898-2.062 4.4 0 1.788.895 3.356 3.968 6.952 3.557 4.16 4