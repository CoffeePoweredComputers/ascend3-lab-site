---
/**
 * SectionHeading — Frosted glass chip with blinking cursor
 * Pattern: >Title_ in a frosted pill chip, with a line extending to the right
 */

interface Props {
  title: string;
  subtitle?: string;
  id?: string;
}

const { title, subtitle, id } = Astro.props;
---

<div class="mb-8 md:mb-12">
  <div class="section-heading-row">
    <h2 id={id} class="section-chip">
      <span class="font-mono text-primary" aria-hidden="true">&gt;</span>{title}<span class="section-cursor font-mono text-primary" aria-hidden="true">_</span>
    </h2>
    <div class="section-line" aria-hidden="true"></div>
  </div>
  {subtitle && (
    <p class="mt-3 text-text-muted max-w-2xl">{subtitle}</p>
  )}
</div>
