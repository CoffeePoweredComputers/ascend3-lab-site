---
/**
 * TerminalBlock — Dark-slate code editor window
 *
 * macOS-style title bar with traffic light dots.
 * Content via <slot />.
 */

interface Props {
  title?: string;
}

const { title = 'terminal' } = Astro.props;
---

<div class="bg-surface-dark border border-slate-700 rounded-xl overflow-hidden">
  <div class="flex items-center gap-2 px-4 py-2.5 bg-slate-800 border-b border-slate-700">
    <span class="w-3 h-3 rounded-full bg-red-500/80" aria-hidden="true"></span>
    <span class="w-3 h-3 rounded-full bg-yellow-500/80" aria-hidden="true"></span>
    <span class="w-3 h-3 rounded-full bg-green-500/80" aria-hidden="true"></span>
    <span class="ml-2 text-slate-400 font-mono text-xs">{title}</span>
  </div>
  <div class="p-4 md:p-6 font-mono text-sm leading-relaxed text-slate-300">
    <slot />
  </div>
</div>
